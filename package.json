{
  "name": "eve-agent-starter",
  "version": "0.0.0",
  "description": "Template base para agentes con Vercel Eve, con un ejemplo funcional de soporte por FAQ.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf .eve .output .workflow-data node_modules pnpm-lock.yaml package-lock.json data",
    "prebuild": "rimraf .eve .output .workflow-data data",
    "build": "eve build",
    "predev": "rimraf .workflow-data data",
    "dev": "dotenv -e .env.local -- eve dev --no-ui --port 2000",
    "dev:ui": "dotenv -e .env.local -- eve dev --port 2000",
    "ngrok": "ngrok http 2000",
    "start": "eve start",
    "preview": "npx nitro preview",
    "typecheck": "tsc",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,json,md}\" --ignore-path .gitignore",
    "lint": "oxlint .",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.7",
    "@vercel/connect": "^0.3.2",
    "ai": "^7.0.15",
    "eve": "^0.19.0",
    "just-bash": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "ngrok": "^4.3.3",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vercel": "^54.20.1",
    "vitest": "^4.1.9"
  }
}

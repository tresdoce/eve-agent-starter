# NODE_ENV se setea desde package.json (cross-env), no acá.
APP_STAGE=local

OPENAI_API_KEY=
# Opcional — default "gpt-4o" (ver agent/agent.ts)
OPENAI_MODEL=
# Opcional — sin setear, usa el default de Eve. Valores: none | minimal | low | medium | high | xhigh
OPENAI_REASONING_EFFORT=

# Shared operator/service credentials for /eve/v1/session in production
# (httpBasic() in agent/channels/eve.ts). Not needed for local dev, which
# is already open via localDev().
ROUTE_AUTH_BASIC_USERNAME=
ROUTE_AUTH_BASIC_PASSWORD=
